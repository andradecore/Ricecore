##--------------- Dmenu Scripts --------------##
# Dmenu App Launcher
super + @space
	dmenu_run -i

# Dmenu Menus
super + c
	~/Others/Scripts/Dmenu/dmenu-menus

# Dmenu Power-Menu
super + x
	~/Others/Scripts/Dmenu/dmenu-power-menu

# Dmenu Clipmenu
super + v
	clipmenu

# Dmenu Emojis
super + period
	~/Others/Scripts/Dmenu/dmenu-emojis

# Dmenu Rbw
super + z
	~/Others/Scripts/Dmenu/dmenu-bwpass

##---------- Shortcut Applications ----------##

# Qutebrowser
super + alt + 1
	qutebrowser

# Discord
super + alt + 2
	Discord

# Minecraft
super + alt + 3
	minecraft-launcher

# Ncspot
super + alt + 4
	st -e ncspot

# Steam
super + alt + 5
	steam

##---------- System Applications ----------##

# Htop
ctrl + shift + Escape
	st -e htop

# Nnn
super + e
        st -e nnn

# Pavucontrol
super + shift + v
        pavucontrol

#Layout Setxkbmap
Shift_L + ctrl
    setxkbmap -query | grep -q 'br' && setxkbmap us || setxkbmap br,us

##---------- System Keys ----------##

# Take a screenshot
@Print
	scrot ~/Pictures/Screenshots/%Y-%m-%d_%H%M%S-$wx$h_screenshot-scrot.png #-e 'xclip -selection clipboard -target image/png -i $f'

# Take a screenshot of area
super + shift + s
	scrot -s --line mode=edge ~/Pictures/Screenshots/%Y-%m-%d_%H%M%S-$wx$h_screenshot-scrot.png #-e 'xclip -selection clipboard -target image/png -i $f'

##---------- Sxhkd Keys ----------##

# Make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

